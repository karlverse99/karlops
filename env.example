# Copy this file to `.env.local` in the `karlops` folder (never commit `.env.local`).
# Next.js and `node scripts/set-user-password.cjs` both read it.

# Browser (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server only — same value as "service_role" secret in Supabase → Settings → API
# Vercel: use either name; the app reads both.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_SECRET_KEY=

# KO / Claude (server routes)
# ANTHROPIC_API_KEY=

# Task modal “Email this log” — Resend (https://resend.com). `from` must be a verified sender/domain in Resend.
# RESEND_API_KEY=re_...
# RESEND_FROM=KarlOps <auth@yourdomain.com>

# TUO Capture outbox (optional) — pending count in KarlOps header; uses TUO Supabase, not KarlOps DB.
# Add these on the *KarlOps* Vercel project (same value as TUO dashboard’s service role, but TUO’s URL + key).
# In Vercel → Settings → Environment Variables: enable for Production (and Preview if you test preview URLs).
# After changing env vars, redeploy (or “Redeploy” latest) so serverless picks them up.
# TUO_SUPABASE_URL=https://YOUR_TUO_PROJECT.supabase.co
# TUO_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Alias: TUO_SUPABASE_SECRET_KEY (same value as service role)

# Optional: opens in a new tab from the header when there are pending captures.
# NEXT_PUBLIC_TUO_CAPTURE_OUTBOX_URL=https://your-tuo.vercel.app/admin/capture-outbox
