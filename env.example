# Copy this file to `.env.local` in the `karlops` folder (never commit `.env.local`).
# Next.js and `node scripts/set-user-password.cjs` both read it.

# Browser (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server only — same value as "service_role" secret in Supabase → Settings → API
# Vercel: use either name; the app reads both.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_SECRET_KEY=

# KO / Claude (server routes)
# ANTHROPIC_API_KEY=
